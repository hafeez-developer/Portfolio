# Server
PORT=3001
NODE_ENV=development

# SMTP
# Resend SMTP example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
ENABLE_AUTO_REPLY=true

# Where contact form messages are delivered
CONTACT_RECEIVER_EMAIL=
